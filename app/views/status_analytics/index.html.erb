<h2><%= l(:label_status_analytics) %>: <%= @project.name %></h2>

<div class="splitcontent">
  <div class="splitcontentleft" style="width: 48%;">
    <div class="box">
      <h3>Kullanıcı Performansı (Gün)</h3>
      <div id="userChart"></div>
    </div>
  </div>
  <div class="splitcontentright" style="width: 48%;">
    <div class="box">
      <h3>Kategori Dağılımı (Gün)</h3>
      <div id="categoryChart"></div>
    </div>
  </div>
</div>

<div class="box" style="margin-top: 20px;">
  <h3>İş Listesi (Detay için Konuya Tıklayın)</h3>
  <table id="analyticsTable" class="list">
    <thead>
      <tr>
        <th># ID</th>
        <th>Konu</th>
        <th>Atanan Kişi</th>
        <th>Son Değişiklik Yapan</th>
        <th>Kategori</th>
        <th>Süre (Gün)</th>
      </tr>
    </thead>
    <tbody>
      <% @is_listesi.each do |is| %>
        <tr>
          <td><%= is[:id] %></td>
          <td style="color: #d63384; cursor: pointer; font-weight: bold;"
               onclick='showIssueDetail(<%= json_escape(is[:subject].to_json) %>, <%= json_escape(is[:lifecycle].to_json) %>)'>
            <%= is[:subject] %>
          </td>
          <td><%= is[:user] %></td>
          <td><%= is[:last_updater] %></td>
          <td><%= is[:category] %></td>
          <td><%= (is[:total_time] / 86400).round(3) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div id="issueModal" style="display:none; position:fixed; z-index:9999; left:0; top:0; width:100%; height:100%; background:rgba(0,0,0,0.7);">
  <div style="background:#fff; margin:10% auto; padding:20px; width:450px; border-radius:12px; text-align:center;">
    <span onclick="document.getElementById('issueModal').style.display='none'" style="float:right; cursor:pointer; font-size:24px;">&times;</span>
    <h3 id="modalTitle" style="color:#d63384; margin-bottom:20px;">İş Detayı</h3>
    <div style="width: 300px; margin: 0 auto;">
      <canvas id="issueDetailChart"></canvas>
    </div>
  </div>
</div>

<link rel="stylesheet" type="text/css" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/d3@7"></script>

<script>
  function createD3Chart(containerId, labels, data) {
    const margin = { top: 20, right: 20, bottom: 60, left: 50 };
    const width = 400 - margin.left - margin.right;
    const height = 250 - margin.top - margin.bottom;

    const svg = d3.select("#" + containerId)
      .append("svg")
      .attr("width", width + margin.left + margin.right)
      .attr("height", height + margin.top + margin.bottom)
      .append("g")
      .attr("transform", `translate(${margin.left},${margin.top})`);

    const dataset = labels.map((label, i) => ({ label, value: data[i] }));

    const x = d3.scaleBand()
      .domain(dataset.map(d => d.label))
      .range([0, width])
      .padding(0.3);

    const y = d3.scaleLinear()
      .domain([0, d3.max(dataset, d => d.value)])
      .nice()
      .range([height, 0]);

    svg.append("g")
      .attr("transform", `translate(0,${height})`)
      .call(d3.axisBottom(x))
      .selectAll("text")
      .attr("transform", "rotate(-30)")
      .style("text-anchor", "end")
      .style("font-size", "11px");

    svg.append("g")
      .call(d3.axisLeft(y).ticks(5));

    svg.selectAll(".bar")
      .data(dataset)
      .enter()
      .append("rect")
      .attr("class", "bar")
      .attr("x", d => x(d.label))
      .attr("y", d => y(d.value))
      .attr("width", x.bandwidth())
      .attr("height", d => height - y(d.value))
      .attr("fill", "rgba(255,182,193,0.8)")
      .attr("rx", 3);

    svg.selectAll(".label")
      .data(dataset)
      .enter()
      .append("text")
      .attr("x", d => x(d.label) + x.bandwidth() / 2)
      .attr("y", d => y(d.value) - 5)
      .attr("text-anchor", "middle")
      .style("font-size", "10px")
      .text(d => d.value > 0 ? d.value.toFixed(1) : "");
  }

  let detailChart;

  window.showIssueDetail = function(subject, lifecycle) {
    document.getElementById('modalTitle').innerText = subject;
    document.getElementById('issueModal').style.display = 'block';
    const ctx = document.getElementById('issueDetailChart').getContext('2d');

    if (detailChart) detailChart.destroy();
    detailChart = new Chart(ctx, {
      type: 'pie',
      data: {
        labels: lifecycle.map(l => l.label),
        datasets: [{
          data: lifecycle.map(l => l.value),
          backgroundColor: ['#ffb6c1', '#ffc0cb', '#db7093', '#ff69b4', '#e75480']
        }]
      }
    });
  };

  document.addEventListener("DOMContentLoaded", function() {
    createD3Chart('userChart', <%= raw @user_labels.to_json %>, <%= raw @user_data.to_json %>);
    createD3Chart('categoryChart', <%= raw @cat_labels.to_json %>, <%= raw @cat_data.to_json %>);

    if (typeof jQuery !== 'undefined') {
      jQuery('#analyticsTable').DataTable({
        "order": [[5, "desc"]],
        "language": { "search": "Hızlı Ara:" }
      });
    }
  });
</script>
